{
  "name": "synthwatch-runner",
  "version": "0.1.0",
  "private": true,
  "description": "SynthWatch data-plane runner: executes HTTP and real-browser synthetic checks on a timer.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "lint:sarif": "eslint . -f @microsoft/eslint-formatter-sarif -o eslint-results.sarif"
  },
  "dependencies": {
    "@azure/communication-email": "1.0.0",
    "@azure/storage-blob": "12.26.0",
    "pg": "8.13.1",
    "playwright": "1.61.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "eslint": "9.39.4",
    "globals": "15.14.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  }
}

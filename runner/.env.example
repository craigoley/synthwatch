# SynthWatch runner — environment configuration.
# Copy to `.env` for local runs. EVERY value here comes from the environment;
# nothing tenant-specific is committed to source. An absent optional var simply
# disables the feature it controls.

# --- Required --------------------------------------------------------------
# Postgres 16 connection string. The runner cannot start without it.
DATABASE_URL=postgres://user:password@localhost:5432/synthwatch

# --- Failure artifacts (optional) ------------------------------------------
# If AZURE_STORAGE_CONNECTION_STRING is unset, screenshot upload silently no-ops.
AZURE_STORAGE_CONNECTION_STRING=
# Blob container for screenshots (defaults to "synthwatch-artifacts").
AZURE_STORAGE_CONTAINER=synthwatch-artifacts

# --- Alert channel 1: Azure Communication Services email (optional) --------
# All three must be set for email alerts to fire.
ACS_EMAIL_CONNECTION_STRING=
ALERT_EMAIL_FROM=
# Comma-separated list of recipient addresses.
ALERT_EMAIL_TO=

# --- Alert channel 2: generic webhook (optional) ---------------------------
# Vendor-neutral escape hatch — point ALERT_WEBHOOK_URL at PagerDuty / Slack /
# any HTTP endpoint that ingests a POST. The runner POSTs a JSON body
# { event, severity, checkId, checkName, summary, runId, failedStep,
#   screenshotUrl, dashboardUrl }. (To add a vendor-native channel instead,
# implement AlertChannel in a fork — see runner/alerts.ts.)
ALERT_WEBHOOK_URL=
# Optional full Authorization header value, e.g. "Basic <base64>" or "Bearer <token>".
ALERT_WEBHOOK_AUTH_HEADER=

# --- Alert dashboard link (optional) ---------------------------------------
# If set, alerts include a deep link to the check: <DASHBOARD_URL>/checks/<id>.
DASHBOARD_URL=
